# ═══════════════════════════════════════════════════════════════
#  SafeKey — App Store 发布配置模板
#  使用方法：
#    cp .env.appstore.example .env.appstore
#    编辑 .env.appstore，填入你的真实值
#    脚本会自动 source 此文件（.gitignore 已排除 .env.appstore）
# ═══════════════════════════════════════════════════════════════

# ── App Store Connect API Key ─────────────────────────────────
# 前往：App Store Connect → 用户和访问 → 集成 → App Store Connect API
# 新建一个"App 管理"角色的 Key，下载 .p8 文件（只能下载一次！）

# Key ID：在 API Key 列表里复制（10位大写字母数字）
ASC_KEY_ID="S2Y8N34JC4"

# Issuer ID：在 API Key 页面顶部复制（UUID 格式）
ASC_ISSUER_ID="27f86c80-db5c-4a86-bf47-b51baaa573e5"

# .p8 文件的绝对路径（把 .p8 文件放到安全位置，不要放项目目录）
ASC_KEY_PATH="/Users/yinchangqi/Desktop/safe_key/ios/AuthKey_S2Y8N34JC4.p8"


# ── Apple Developer 信息 ──────────────────────────────────────
# Apple ID（你登录开发者后台用的邮箱）
APPLE_ID="745846966@qq.com"

# Developer Team ID（10位，在开发者后台 → Membership 页面查看）
APPLE_TEAM_ID="WMKE6PQLTZ"

# App Store Connect Team ID（纯数字，在 App Store Connect URL 里可以看到）
# 如果你只有一个团队，可以留空，fastlane 会自动选择
ITC_TEAM_ID=""


# ── 版本号 ────────────────────────────────────────────────────
# 营销版本与构建号由 scripts/deploy_appstore.sh 传入（-v / -n），
# 未传时从 pubspec.yaml 的 version: x.y.z+build 读取。
